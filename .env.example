# Environment Variables Template
# Copy this file to .env and replace the placeholders with your actual API keys.

# Required: Google Gemini API Key
GEMINI_API_KEY=YOUR_KEY_HERE

# Required: Groq API Key (used for fallback and ReAct Agent)
GROQ_API_KEY=YOUR_KEY_HERE

# Optional: Sarvam AI API Key (used for bilingual generation and high-fidelity TTS)
SARVAM_API_KEY=YOUR_KEY_HERE

# Optional: E-Book and Administration Passwords
EBOOK_PASSWORD=readkarana
ADMIN_PASSWORD=admin123
